# Netlify Headers — Long-term caching for static assets
# Fonts: 1 year cache (immutable, versioned filenames)
https://clearing-ai.com/fonts/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS: 1 week cache (may change with deployments)
https://clearing-ai.com/css/*
  Cache-Control: public, max-age=604800, no-cache

https://clearing-ai.com/js/*
  Cache-Control: public, max-age=604800, no-cache

# Static assets: 1 month
https://clearing-ai.com/assets/*
  Cache-Control: public, max-age=2592000