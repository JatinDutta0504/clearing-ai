  <script src="main.js"></script>
  <script>
    // Reading progress bar
    var progressBar = document.getElementById('reading-progress');
    var article = document.querySelector('.page-content');
    if (progressBar && article) {
      window.addEventListener('scroll', function() {
        var rect = article.getBoundingClientRect();
        var total = article.offsetHeight - window.innerHeight;
        var scrolled = Math.max(0, -rect.top);
        var pct = Math.min(100, Math.round((scrolled / total) * 100));
        progressBar.style.width = pct + '%';
      }, { passive: true });
    }

    // FAQ accordion
    document.querySelectorAll('.faq-item summary').forEach(function(summary) {
      summary.addEventListener('click', function(e) {
        var details = summary.parentElement;
        if (details.hasAttribute('open')) {
          details.removeAttribute('open');
        }
      });
    });

    // Reading time
    var readTimeEl = document.getElementById('read-time');
    if (readTimeEl) {
      var text = (document.querySelector('.page-content') || {}).innerText || '';
      var words = text.trim().split(/\s+/).length;
      var mins = Math.ceil(words / 220);
      readTimeEl.textContent = mins + ' min read';
    }

    // ML Engineer fatigue checklist
    var checklistItems = document.querySelectorAll('.checklist-item input[type="checkbox"]');
    var checklistResult = document.getElementById('checklist-result');

    function updateChecklistResult() {
      var checked = document.querySelectorAll('.checklist-item input[type="checkbox"]:checked').length;
      if (checked === 0) {
        checklistResult.innerHTML = '';
      } else if (checked <= 2) {
        checklistResult.innerHTML = '<p class="result low">⚠️ ' + checked + ' sign(s) checked. Mild ML-specific fatigue — consider protecting more deep reading time and raising reproducibility concerns with your team.</p>';
      } else if (checked <= 4) {
        checklistResult.innerHTML = '<p class="result mid">⚡ ' + checked + ' sign(s) checked. Moderate ML engineer fatigue — research pressure and ethics weight are compounding. See the sustainable practice section.</p>';
      } else {
        checklistResult.innerHTML = '<p class="result high">🔥 ' + checked + ' sign(s) checked. Significant ML-specific fatigue — consider raising these issues with your team lead, and revisit the irreplaceable skills section.</p>';
      }
    }

    checklistItems.forEach(function(cb) {
      cb.addEventListener('change', updateChecklistResult);
    });
  </script>
